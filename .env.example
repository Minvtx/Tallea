# Tallea local defaults
# Copy to .env.local for local development. Configure these in Vercel for production.

# Mutable world memory: file for local JSON files, postgres for Neon/Postgres.
TALLEA_WORLD_STORE=file

# Required only when TALLEA_WORLD_STORE=postgres.
# Neon from Vercel Marketplace usually provides DATABASE_URL automatically.
DATABASE_URL=
POSTGRES_URL=

# Cycle execution: direct for local/dev, workflow for Vercel production.
TALLEA_CYCLE_RUNNER=direct

# AI generation master switch. false keeps deterministic mock mode.
TALLEA_ENABLE_AI=false

# AI provider: gateway is preferred on Vercel; openai uses @ai-sdk/openai directly.
# If unset in code, Tallea prefers gateway when AI_GATEWAY_API_KEY exists.
TALLEA_AI_PROVIDER=gateway

# Vercel AI Gateway key, required for TALLEA_AI_PROVIDER=gateway.
AI_GATEWAY_API_KEY=

# Direct OpenAI fallback key, required for TALLEA_AI_PROVIDER=openai.
OPENAI_API_KEY=

# Gateway model ids usually include a provider prefix, e.g. openai/gpt-4o-mini.
# Direct OpenAI model ids do not, e.g. gpt-4o-mini.
TALLEA_AI_MODEL=openai/gpt-4o-mini
TALLEA_AI_TEMPERATURE=0.7

# Vercel Cron bearer token. Required in production.
CRON_SECRET=

# Simple admin guard. Required in production; /admin is blocked without it.
ADMIN_SECRET=

# Workflow DevKit usually configures itself through @workflow/next.
# Optional local/debug overrides exposed by the installed packages:
# WORKFLOW_TARGET_WORLD=local
# WORKFLOW_LOCAL_DATA_DIR=.next/workflow-data
# WORKFLOW_LOCAL_BASE_URL=http://localhost:3000
# WORKFLOW_PUBLIC_MANIFEST=1
# WORKFLOW_VERCEL_BACKEND_URL=
# VERCEL_TOKEN=
